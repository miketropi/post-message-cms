# SQLite (default). For MySQL later, set provider in prisma/schema.prisma and use a mysql:// URL.
DATABASE_URL="file:./prisma/dev.db"

# Required for admin sessions (JWT in HttpOnly cookie). Min 32 chars. Example: openssl rand -base64 32
AUTH_SECRET=""

# Optional: automated POST /api/admin/cleanup — send header Authorization: Bearer <same value>.
# If set, omit JSON workspaceId to clean every workspace (each uses its own messageRetentionDays).
# Example: openssl rand -base64 32
CRON_SECRET=""

# Optional: outbound email (nodemailer) for password-change notices, forgot-password links, etc. Requires SMTP_HOST and SMTP_FROM.
# SMTP_PORT defaults to 587; SMTP_SECURE "true" uses TLS on connect (often port 465).
# SMTP_USER / SMTP_PASS omit for servers that allow unauthenticated relay (rare in production).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
